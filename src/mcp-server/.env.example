# --- MCP Server Configuration ---
MCP_TRANSPORT=streamable-http
MCP_HOST=0.0.0.0
MCP_PORT=8080
LOG_LEVEL=INFO

# --- Document Tools ---
# Mount a local directory to make documents available
MCP_DOCUMENTS_DIR=/data/documents

# --- Web Search ---
BRAVE_API_KEY=
BRAVE_API_URL=https://api.search.brave.com/res/v1/web/search
TAVILY_API_KEY=
RAG_WEB_SEARCH_MAX_RESULTS=5

# --- Legifrance / Judilibre ---
LEGIFRANCE_API_BASE_URL=https://api.piste.gouv.fr/dila/legifrance/lf-engine-app
LEGIFRANCE_OAUTH_URL=https://oauth.piste.gouv.fr/api/oauth/token
LEGIFRANCE_CLIENT_ID=
LEGIFRANCE_CLIENT_SECRET=
LEGIFRANCE_API_TOKEN=
LEGIFRANCE_SSL_VERIFY=true
LEGIFRANCE_OAUTH_HOST=
LEGIFRANCE_API_HOST=

JUDILIBRE_API_URL=https://api.piste.gouv.fr/cassation/judilibre/v1.0
JUDILIBRE_KEY_NAME=KeyId
